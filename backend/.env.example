# Copy to .env and fill in. Never commit .env.

ENV=dev
APP_VERSION=0.1.0
LOG_LEVEL=INFO

# Database (Supabase Session Pooler) — Sprint 1 Day 2
# Get from Supabase dashboard → Project Settings → Database → Connect → Session pooler
DATABASE_URL=postgresql://postgres.<project_ref>:<password>@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres

# Redis cache (Upstash) — Sprint 1 Day 10
REDIS_URL=redis://localhost:6379/0

# Karnataka RERA portal — Sprint 1 Day 6
RERA_KARNATAKA_BASE=https://rera.karnataka.gov.in

# Twilio (WhatsApp) — Sprint 2
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=

# Image search — Sprint 2
GOOGLE_VISION_API_KEY=

# Notifications
RESEND_API_KEY=
ALERT_EMAIL=hello@propcheck.in
